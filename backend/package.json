{
  "name": "nexpert-ai-backend",
  "version": "1.0.0",
  "description": "Huascaran restaurant AI agent backend for the public web chat widget",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "restaurant:dev": "tsx src/restaurant/local-server.ts",
    "restaurant:smoke": "tsx src/restaurant/smoke.ts",
    "restaurant:acceptance": "tsx src/restaurant/acceptance-runner.ts",
    "restaurant:build": "tsc -p tsconfig.restaurant.json",
    "restaurant:typecheck": "tsc --noEmit -p tsconfig.restaurant.json",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.49",
    "@fastify/cors": "11.0.0",
    "@fastify/helmet": "13.0.1",
    "@fastify/rate-limit": "10.2.1",
    "@fastify/sensible": "6.0.3",
    "@google-cloud/vision": "4.3.2",
    "ai": "^6.0.141",
    "drizzle-orm": "0.38.4",
    "fastify": "5.2.1",
    "openai": "4.85.4",
    "pino": "9.6.0",
    "pino-pretty": "13.0.0",
    "postgres": "3.4.5",
    "puppeteer-core": "24.4.0",
    "stripe": "17.7.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "22.13.10",
    "@typescript-eslint/eslint-plugin": "8.26.1",
    "@typescript-eslint/parser": "8.26.1",
    "drizzle-kit": "0.30.5",
    "eslint": "9.22.0",
    "tsx": "4.19.3",
    "typescript": "5.7.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
