# Huascaran Restaurante
# Copy these values into the Coolify environment panel.

NODE_ENV=production
PORT=3000
HOST=0.0.0.0
TZ=America/Lima

# Admin login
ADMIN_EMAIL=admin@huascaran.ai
ADMIN_PASSWORD=change-me-with-openssl-rand-base64-24

# Restaurant AI agent
HUASCARAN_USE_DEEPSEEK=1
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=huascaran_menu

# Frontend uses same-origin API in production.
VITE_RESTAURANT_API_URL=
